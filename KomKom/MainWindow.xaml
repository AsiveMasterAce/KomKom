<Window x:Class="KomKom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KomKom"
        mc:Ignorable="d"
        Title="KomKom - Task Manager" Height="600" Width="950"
        Background="#F5F7FA"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D5DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Small Button Style -->
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Task Item Style -->
        <Style x:Key="TaskItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="10" 
                                Padding="16,12"
                                Margin="{TemplateBinding Margin}">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="8" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF2FF"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F9FAFB"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Task List -->
        <Border Grid.Column="0" 
                Background="White" 
                CornerRadius="16" 
                Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="📋 My Tasks" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#1F2937"/>
                    <TextBlock Text="Schedule and manage your day" 
                               FontSize="13" 
                               Foreground="#6B7280" 
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Task List -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox ItemsSource="{Binding Tasks}" 
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource TaskItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Time Badge -->
                                    <Border Grid.Column="0" 
                                            Background="#EEF2FF" 
                                            CornerRadius="6" 
                                            Padding="8,4"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding StartTime, StringFormat=HH:mm}" 
                                                   FontSize="12" 
                                                   FontWeight="SemiBold"
                                                   Foreground="#4F46E5"/>
                                    </Border>

                                    <!-- Task Info -->
                                    <StackPanel Grid.Column="1" 
                                                Margin="12,0,0,0" 
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" 
                                                   FontSize="15" 
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"/>
                                        <TextBlock FontSize="12" 
                                                   Foreground="#6B7280"
                                                   Margin="0,2,0,0">
                                            <Run Text="{Binding DurationMinutes, StringFormat={}{0} min}"/>
                                            <Run Text="•"/>
                                            <Run Text="{Binding StartTime, StringFormat=dddd}"/>
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- Duration Badge -->
                                    <Border Grid.Column="2" 
                                            Background="#F3F4F6" 
                                            CornerRadius="6" 
                                            Padding="8,4"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="⏱" 
                                                   FontSize="14"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Add Task Button -->
                <Button Grid.Row="2" 
                        Content="+ Add New Task" 
                        Command="{Binding AddTaskCommand}"
                        Style="{StaticResource ModernButton}"
                        Margin="0,16,0,0"
                        Height="44"/>
            </Grid>
        </Border>

        <!-- RIGHT PANEL: Timer -->
        <Border Grid.Column="1" 
                Background="White" 
                CornerRadius="16" 
                Padding="32"
                Margin="20,0,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Timer Header -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="⏰ Pomodoro Timer" 
                               FontSize="26" 
                               FontWeight="Bold" 
                               Foreground="#1F2937"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Focus on your work with timed sessions" 
                               FontSize="14" 
                               Foreground="#6B7280" 
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Timer Display -->
                <Viewbox Grid.Row="1" 
                         VerticalAlignment="Center"
                         HorizontalAlignment="Center"
                         Margin="0,40,0,40">
                    <Border Background="#F9FAFB" 
                            CornerRadius="30" 
                            Padding="60,40"
                            BorderBrush="#E5E7EB"
                            BorderThickness="2">
                        <StackPanel>
                            <TextBlock Text="{Binding TimerDisplayString}" 
                                       FontSize="96" 
                                       FontWeight="Bold" 
                                       Foreground="#4F46E5"
                                       HorizontalAlignment="Center"
                                       FontFamily="Segoe UI, Consolas"/>
                            <TextBlock Text="minutes remaining" 
                                       FontSize="16" 
                                       Foreground="#6B7280"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Viewbox>

                <!-- Time Adjustment Controls -->
                <StackPanel Grid.Row="2" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                    <Button Content="-30s" 
                            Command="{Binding DecreaseTimeCommand}"
                            Style="{StaticResource SmallButton}"
                            Width="80"
                            Height="40"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="Adjust Time" 
                               FontSize="14"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               Margin="8,0"/>
                    <Button Content="+30s" 
                            Command="{Binding IncreaseTimeCommand}"
                            Style="{StaticResource SmallButton}"
                            Width="80"
                            Height="40"
                            Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Control Buttons -->
                <StackPanel Grid.Row="3" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center">
                    <Button Content="▶ Start 25 min" 
                            Command="{Binding StartTimerCommand}"
                            Style="{StaticResource ModernButton}"
                            Width="160"
                            Height="50"
                            FontSize="15"
                            Margin="0,0,12,0"/>
                    <Button Content="⏸ Pause" 
                            Command="{Binding PauseTimerCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="120"
                            Height="50"
                            FontSize="15"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>