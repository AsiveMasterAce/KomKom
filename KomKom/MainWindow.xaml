<Window x:Class="KomKom.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KomKom"
        mc:Ignorable="d"
        Title="KomKom - Task Manager" Height="600" Width="950"
        Background="#F5F7FA"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Modern Button Style -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="#4F46E5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4338CA"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#9CA3AF"/>
                    <Setter Property="Cursor" Value="Arrow"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D1D5DB"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TaskAmberButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="TaskRedButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <Style x:Key="TaskGreenButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Background" Value="#10B981"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Height" Value="30"/>
        </Style>

        <!-- Small Button Style -->
        <Style x:Key="SmallButton" TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!-- Timer Preset Selector Style -->
        <Style x:Key="TimerPresetItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,8,8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="MinWidth" Value="56"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="PresetBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="12,8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="PresetBorder" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="PresetBorder" Property="Background" Value="#4F46E5"/>
                                <Setter TargetName="PresetBorder" Property="BorderBrush" Value="#4F46E5"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="PresetBorder" Property="Background" Value="#E5E7EB"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Task Item Style -->
        <Style x:Key="TaskItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="TaskCard"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14"
                                Padding="16,14"
                                MinHeight="128"
                                Margin="{TemplateBinding Margin}">
                            <Border.Effect>
                                <DropShadowEffect Color="#0F172A" Opacity="0.06" BlurRadius="12" ShadowDepth="2"/>
                            </Border.Effect>
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <DataTrigger Binding="{Binding Completed}" Value="True">
                                <Setter TargetName="TaskCard" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="TaskCard" Property="Opacity" Value="0.72"/>
                            </DataTrigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TaskCard" Property="Background" Value="#F8FAFC"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TaskCard" Property="Background" Value="#EEF2FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="380" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- LEFT PANEL: Task List -->
        <Border Grid.Column="0" 
                Background="White" 
                CornerRadius="16" 
                Padding="20">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="My Tasks" 
                               FontSize="24" 
                               FontWeight="Bold" 
                               Foreground="#1F2937"/>
                    <TextBlock Text="Organize tasks by priority and tags" 
                               FontSize="13" 
                               Foreground="#6B7280" 
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Task List -->
                <ScrollViewer Grid.Row="1" 
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ListBox ItemsSource="{Binding Tasks}" 
                             Background="Transparent"
                             BorderThickness="0"
                             ItemContainerStyle="{StaticResource TaskItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid VerticalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Task Status -->
                                    <Border Grid.Column="0"
                                            Grid.Row="0"
                                            Grid.RowSpan="2"
                                            Width="34"
                                            Height="34"
                                            Background="#EEF2FF"
                                            CornerRadius="17"
                                            VerticalAlignment="Top"
                                            Margin="0,2,12,0">
                                        <TextBlock Text="•"
                                                   FontSize="18"
                                                   FontWeight="Bold"
                                                   Foreground="#4F46E5"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Completed}" Value="True">
                                                            <Setter Property="Text" Value="✓"/>
                                                            <Setter Property="Foreground" Value="#10B981"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>

                                    <!-- Task Info -->
                    <StackPanel Grid.Column="1"
                        Grid.Row="0"
                        VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   Foreground="#0F172A">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Completed}" Value="True">
                                                            <Setter Property="Foreground" Value="#94A3B8"/>
                                                            <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Category}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   Foreground="#B45309"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <!-- Details -->
                                    <StackPanel Grid.Column="1"
                                                Grid.Row="1"
                                                Margin="0,8,0,0">
                                        <TextBlock Text="{Binding DurationMinutes, StringFormat={}{0} min}"
                                                   FontSize="12"
                                                   Foreground="#475569"/>
                                        <TextBlock Text="{Binding StartTime, StringFormat={}{0:MMM d, h:mm tt}}"
                                                   FontSize="12"
                                                   Foreground="#64748B"
                                                   Margin="0,4,0,0"/>
                                        <TextBlock Text="Details shown below the title so the card stays compact."
                                                   FontSize="11"
                                                   Foreground="#94A3B8"
                                                   Margin="0,4,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <!-- Actions -->
                                    <StackPanel Grid.Column="1"
                                                Grid.Row="2"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Left"
                                                Margin="0,10,0,0">
                                        <Button Content="↑"
                                                Command="{Binding DataContext.IncreasePriorityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TaskAmberButton}"
                                                Width="40"
                                                Height="30"
                                                FontSize="12"
                                                Margin="0,0,6,0"/>
                                        <Button Content="↓"
                                                Command="{Binding DataContext.DecreasePriorityCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TaskRedButton}"
                                                Width="40"
                                                Height="30"
                                                FontSize="12"
                                                Margin="0,0,6,0"/>
                                        <Button Content="Done"
                                                Command="{Binding DataContext.ToggleTaskCompletedCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource TaskGreenButton}"
                                                Width="56"
                                                Height="30"
                                                FontSize="11"
                                                Margin="0"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>

                <!-- Add Task Button -->
                <Button Grid.Row="2" 
                        Content="Add Task" 
                        Command="{Binding AddTaskCommand}"
                        Style="{StaticResource ModernButton}"
                        Margin="0,16,0,0"
                        Height="44"/>
            </Grid>
        </Border>

        <!-- RIGHT PANEL: Timer -->
        <Border Grid.Column="1" 
                Background="White" 
                CornerRadius="16" 
                Padding="32"
                Margin="20,0,0,0">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.08" BlurRadius="20" ShadowDepth="4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Timer Header -->
                <StackPanel Grid.Row="0">
                    <TextBlock Text="Pomodoro Timer" 
                               FontSize="26" 
                               FontWeight="Bold" 
                               Foreground="#1F2937"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Focus on your work with timed sessions" 
                               FontSize="14" 
                               Foreground="#6B7280" 
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="{Binding SelectedTimerPreviewText}"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#4F46E5"
                               HorizontalAlignment="Center"
                               Margin="0,6,0,0"
                               Visibility="{Binding HasSelectedTimer, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>

                <!-- Timer Display -->
                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="0,20,0,20">
                    <Viewbox VerticalAlignment="Center"
                             HorizontalAlignment="Center">
                        <Border x:Name="TimerCard"
                                Background="#F9FAFB" 
                                CornerRadius="30" 
                                Padding="48,30"
                                BorderBrush="#E5E7EB"
                                BorderThickness="2"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="#E5E7EB"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsTimerRunning}" Value="True">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard x:Name="TimerPulseStoryboard">
                                                    <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                                         To="1.03"
                                                                         Duration="0:0:0.8"/>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                                         To="1.03"
                                                                         Duration="0:0:0.8"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <StopStoryboard BeginStoryboardName="TimerPulseStoryboard"/>
                                            </DataTrigger.ExitActions>
                                            <Setter Property="BorderBrush" Value="#4F46E5"/>
                                            <Setter Property="BorderThickness" Value="3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <TextBlock Text="{Binding TimerDisplaySafeString}" 
                                           FontSize="80" 
                                           FontWeight="Bold" 
                                           Foreground="#4F46E5"
                                           HorizontalAlignment="Center"
                                           FontFamily="Segoe UI, Consolas"/>
                                <TextBlock Text="minutes remaining" 
                                           FontSize="16" 
                                           Foreground="#6B7280"
                                           HorizontalAlignment="Center"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Viewbox>
                </StackPanel>

                <!-- Time Adjustment Controls + Selector -->
                <StackPanel Grid.Row="2"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,12">
                        <Button Content="-30s" 
                                Command="{Binding DecreaseTimeCommand}"
                                Style="{StaticResource SmallButton}"
                                Width="80"
                                Height="40"
                                Margin="0,0,8,0"/>
                        <TextBlock Text="Adjust Time" 
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>
                        <Button Content="+30s" 
                                Command="{Binding IncreaseTimeCommand}"
                                Style="{StaticResource SmallButton}"
                                Width="80"
                                Height="40"
                                Margin="8,0,0,0"/>
                    </StackPanel>

                    <StackPanel Orientation="Vertical"
                                HorizontalAlignment="Center">
                        <TextBlock Text="Session Length"
                                   FontSize="14"
                                   Foreground="#6B7280"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <ListBox ItemsSource="{Binding TimerOptions}"
                                 SelectedItem="{Binding SelectedTimerMinutes, Mode=TwoWay}"
                                 IsEnabled="{Binding IsTimerSelectionEnabled}"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ItemContainerStyle="{StaticResource TimerPresetItemStyle}"
                                 HorizontalAlignment="Center">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat={}{0} min}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </StackPanel>

                <!-- Control Buttons -->
                <StackPanel Grid.Row="3" 
                            Orientation="Horizontal" 
                            HorizontalAlignment="Center">
                        <Button Content="Start Timer" 
                            Command="{Binding StartTimerCommand}"
                            Style="{StaticResource ModernButton}"
                            Width="160"
                            Height="50"
                            FontSize="15"
                            Margin="0,0,12,0"/>
                    <Button Content="Pause" 
                            Command="{Binding PauseTimerCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Width="120"
                            Height="50"
                        FontSize="15"
                        Margin="0,0,12,0"/>
                    <Button Content="Reset" 
                        Command="{Binding ResetTimerCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Width="120"
                        Height="50"
                        FontSize="15"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>